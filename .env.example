# Canva API 環境変数設定
# このファイルを .env にリネームして、実際の値を入力してください

# Canva Developer Portal から取得した認証情報
# 取得方法: https://www.canva.com/developers/api

CANVA_CLIENT_ID=your_client_id_here
CANVA_CLIENT_SECRET=your_client_secret_here
CANVA_REDIRECT_URI=http://localhost:3000/auth/canva/callback

# メニュー表のデザインID（CanvaデザインのURLから取得できます）
# 例: https://www.canva.com/design/DAF_xxxxxxxxxx/Edit
# デザインID: DAF_xxxxxxxxxx
CANVA_MENU_DESIGN_ID=

# アクセストークン（OAuth 2.0 認証後に自動設定されます）
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# トークンの有効期限（自動設定）
CANVA_TOKEN_EXPIRES_AT=

# 開発モード
NODE_ENV=development
